\begin_layout Standard
\begin_inset CommandInset label
LatexCommand label
name "alg:SelectVector"

\end_inset


\end_layout

\begin_layout Standard
Let 
\begin_inset Formula $I=\{\}$
\end_inset

 be the set of coordinates to update.
\end_layout

\begin_layout Standard
\begin_inset ERT
status open

\begin_layout Plain Layout

\backslash
