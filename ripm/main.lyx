\begin_layout Standard
\begin_inset Formula $I=I\cup\{i:|v^{(k)}_{i}-v^{(k-2^{\ell})}_{i}|\geq\delta/(2\left\lceil \log n\right\rceil )\}$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset ERT
status open

\begin_layout Plain Layout
}
