\end_inset

 on an 
\begin_inset Formula $n$
\end_inset

-element set,
 it is of interest to count the number of linear extensions,
 i.e.,
 total orders on the set that are consistent with 
\begin_inset Formula $P$
\end_inset

.
 We can define an associated polyhedron,
 
\begin_inset Formula 
\[
Q=\left\{ x\in[0,1]^{n}:\,x_{i}<x_{j}\mbox{ if }(i,j)\in P\right\} .
\]

\end_inset

Show that the number of linear extensions of 
\begin_inset Formula $P$
\end_inset

 is exactly 
\begin_inset Formula $\vol(Q)n!$
\end_inset

.
 
\end_layout

\begin_layout Section
Proof of the Brunn-Minkowski Inequality
\begin_inset CommandInset label
LatexCommand label
name "sec:Proof-of-BM"

\end_inset


\end_layout

\begin_layout Standard
Here we prove Theorem 
\begin_inset CommandInset ref
LatexCommand ref
reference "thm:Brunn-Minkowski"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

.
 Let 
\begin_inset Formula $A,B\subset\R^{n}$
\end_inset

 be measurable subsets.
 Our goal is to show that 
\begin_inset Formula 
\[
\vol(\lambda A+(1-\lambda)B)^{1/n}\ge\lambda\vol(A)^{1/n}+(1-\lambda)\vol(B)^{1/n}.
\]

\end_inset

By setting 
\begin_inset Formula $A'=\lambda A$
\end_inset

 and 
\begin_inset Formula $B'=(1-\lambda)B$
\end_inset

,
 this is equivalent to showing that for all measurable 
\begin_inset Formula $A,B$
\end_inset

:
\begin_inset Formula 
\begin{equation}
\vol(A+B)^{1/n}\ge\vol(A)^{1/n}+\vol(B)^{1/n}.\label{eq:BM-ineq}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
We first consider the case when 
\begin_inset Formula $A,B$
\end_inset

 are cuboids,
 i.e.,
 
\begin_inset Formula 
\[
A=\prod_{i=1}^{n}[0,a_{i}]\ \mbox{and \ }B=\prod_{i=1}^{n}[0,b_{i}]
\]

\end_inset

for positive real numbers 
\begin_inset Formula $a_{1},\ldots,a_{m},b_{1},\ldots,b_{m}$
\end_inset

.
 Then,
 we have 
\begin_inset Formula 
\[
\vol(A)=\prod_{i=1}^{n}a_{i},\,\vol(B)=\prod_{i=1}^{n}b_{i}\:\vol(A+B)=\prod_{i=1}^{n}(a_{i}+b_{i}).
\]

\end_inset

Now we need to verify that 
\begin_inset Formula 
\[
\left(\prod_{i=1}^{n}(a_{i}+b_{i})\right)^{\frac{1}{n}}\ge\left(\prod_{i=1}^{n}a_{i}\right)^{\frac{1}{n}}+\left(\prod_{i=1}^{n}b_{i}\right)^{\frac{1}{n}}
\]

\end_inset

which is equivalent to 
\begin_inset Formula 
\[
\left(\prod_{i=1}^{n}\frac{a_{i}}{a_{i}+b_{i}}\right)^{\frac{1}{n}}+\left(\prod_{i=1}^{n}\frac{b_{i}}{a_{i}+b_{i}}\right)^{\frac{1}{n}}\le1.
\]

\end_inset

Using the AM-GM inequality,
 for each of the terms on the LHS,
 we have 
\begin_inset Formula 
\[
\left(\prod_{i=1}^{n}\frac{a_{i}}{a_{i}+b_{i}}\right)^{\frac{1}{n}}+\left(\prod_{i=1}^{n}\frac{b_{i}}{a_{i}+b_{i}}\right)^{\frac{1}{n}}\le\frac{1}{n}\sum_{i=1}^{n}\frac{a_{i}}{a_{i}+b_{i}}+\frac{1}{n}\sum_{i=1}^{n}\frac{b_{i}}{a_{i}+b_{i}}=1.
\]

\end_inset


\end_layout

\begin_layout Standard
We will now prove the inequality to any finite union of cuboids.
 That suffices to complete the proof because any measurable subset is the limit of a union of disjoint cubes as the cubes become smaller and smaller.
 
\end_layout

\begin_layout Standard
Let 
\begin_inset Formula $A$
\end_inset

 be a finite collection of disjoint axis-parallel cuboids and 
\begin_inset Formula $B$
\end_inset

 be another such collection.
 We will prove the inequality by induction on the total number of cuboids in 
\begin_inset Formula $A\cup B$
\end_inset

.
 First note that there is at least one complete cuboid of 
\begin_inset Formula $A$
\end_inset

 separated from another complete cuboid of 
\begin_inset Formula $A$
\end_inset

 by an axis-aligned halfspace,
 i.e.,
 there is a coordinate 
\begin_inset Formula $i$
\end_inset

 so that after translating 
\begin_inset Formula $A$
\end_inset

 along this coordinate the sets 
\begin_inset Formula ${x:x_{i}\le0}$
\end_inset

and 
\begin_inset Formula ${x:x_{i}>0}$
\end_inset

 both contain a complete cuboid of 
\begin_inset Formula $A$
\end_inset

.
 This follows from the fact that disjoint axis-parallel cuboids can be separated by an axis-parallel halfspace.
 Now define the following sets:
\begin_inset Formula 
\begin{align*}
A^{+} & =A\cap\left\{ x:x_{i}>0\right\} \ \ A^{-}=A\setminus A^{+}\\
B^{+} & =B\cap\left\{ x:x_{i}>0\right\} \ \ B^{-}=B\setminus B^{+}.
\end{align*}

\end_inset

Translate 
\begin_inset Formula $B$
\end_inset

 so that we have 
\begin_inset Formula 
\begin{equation}
\frac{\vol(A^{+})}{\vol(A)}=\frac{\vol(B^{+})}{\vol(B^{-})}.\label{eq:AB_ratio}
\end{equation}

\end_inset

(Translation only translates the Minkowski sum.) Since 
\begin_inset Formula $A^{+}\cup B^{+}$
\end_inset

 and 
\begin_inset Formula $A^{-}\cup B^{-}$
\end_inset

 are both smaller collections of cuboids compared to 
\begin_inset Formula $A\cup B$
\end_inset

,
 we can apply the B-M inequality 
\begin_inset CommandInset ref
LatexCommand eqref
reference "thm:Brunn-Minkowski"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 to them inductively.
 We already proved the base case when each of 
\begin_inset Formula $A,B$
\end_inset

 is a single cuboid.
 Using induction in the second step and the identity 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:AB_ratio"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 in the fourth step,
 we have (note that the sets 
\begin_inset Formula $A^{+}+B^{+}$
\end_inset

and 
\begin_inset Formula $A^{-}+B^{-}$
\end_inset

 are disjoint and contained in 
\begin_inset Formula $A+B$
\end_inset

):
\begin_inset Formula 
\begin{align*}
\vol(A+B) & \ge\vol(A^{+}+B^{+})+\vol(A^{-}+B^{-})\\
 & \ge\left(\vol(A^{+})^{1/n}+\vol(B^{+})^{1/n}\right)^{n}+\left(\vol(A^{-})^{1/n}+\vol(B^{-})^{1/n}\right)^{n}\\
 & =\vol(A^{+})\left(1+\frac{\vol(B^{+})^{1/n}}{\vol(A^{+})^{1/n}}\right)^{n}+\vol(A^{-})\left(1+\frac{\vol(B^{-})^{1/n}}{\vol(A^{-})^{1/n}}\right)^{n}\\
 & =\vol(A^{+})\left(1+\frac{\vol(B)^{1/n}}{\vol(A)^{1/n}}\right)^{n}+\vol(A^{-})\left(1+\frac{\vol(B)^{1/n}}{\vol(A)^{1/n}}\right)^{n}\\
 & =\vol(A)\left(1+\frac{\vol(B)^{1/n}}{\vol(A)^{1/n}}\right)^{n}\\
 & =\left(\vol(A)^{1/n}+\vol(B)^{1/n}\right)^{n}
\end{align*}

\end_inset

which completes the proof.
\end_layout

